{
  // Visit https://aka.ms/tsconfig to read more about this file
  "compilerOptions": {
    // File Layout
    "rootDirs": [
      "./src",
      "./generated/prisma"
    ],
    "paths": {
      "@prisma/client": ["./generated/prisma"],},
    "outDir": "./dist",

    // Environment Settings
    // See also https://aka.ms/tsconfig/module
    "module": "ESNext",
    "target": "esnext",
    "types": [],
    // For nodejs:
    // "lib": ["esnext"],
    // "types": ["node"],
    // and npm install -D @types/node

    // Other Outputs
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "moduleResolution": "Bundler",
    // Stricter Typechecking Options
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "resolveJsonModule": true,

    // Style Options
    // "noImplicitReturns": true,
    // "noImplicitOverride": true,
    // "noUnusedLocals": true,
    // "noUnusedParameters": true,
    // "noFallthroughCasesInSwitch": true,
    // "noPropertyAccessFromIndexSignature": true,

    // Recommended Options
    "strict": true,
    "jsx": "react-jsx",
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
  },
  "include": [
    "src/**/*",
    "generated/prisma/**/*"                          // 💡 Only compile files inside the src directory
  ],
  "exclude": [
    "node_modules",
    "dist",
    "prisma",                            // 💡 Tells tsc to ignore your prisma schema folder
    "generated",                         // 💡 Tells tsc to ignore the generated browser artifacts causing the crash
    "prisma.config.ts"                   // 💡 Explicitly ignores the config file outside your rootDir
  ]
}
